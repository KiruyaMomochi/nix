+def _path_fill_shell_prelude(env: dict) -> str:
+    """Shell snippet that re-applies parent PATH after login profiles run.
+
+    NixOS' /etc/profile sources a generated set-environment script that can
+    replace PATH inside ``bash -l``. Since that happens after Popen receives
+    our env, Python-side PATH repair alone can be lost during the snapshot.
+    This prelude runs inside the login shell, after system/user profiles, and
+    appends any trusted parent-process PATH entries still missing at that
+    point (plus conservative standard/user fill-ins for sparse service envs).
+    """
+    if _IS_WINDOWS:
+        return ""
+    quoted = " ".join(shlex.quote(entry) for entry in _path_repair_entries(env))
+    if not quoted:
+        return ""
+    return (
+        "for __hermes_path_entry in " + quoted + "; do\n"
+        "  [ -n \"$__hermes_path_entry\" ] || continue\n"
+        "  case \":$PATH:\" in\n"
+        "    *:\"$__hermes_path_entry\":*) ;;\n"
+        "    *) PATH=\"${PATH:+$PATH:}$__hermes_path_entry\" ;;\n"
+        "  esac\n"
+        "done\n"
+        "export PATH\n"
+        "unset __hermes_path_entry\n"
+    )
 
 
