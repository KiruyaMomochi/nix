+# Standard PATH entries for environments with minimal PATH.  Keep the string
+# form for backward compatibility with any external imports, but treat the
+# tuple below as the canonical list so we can add missing entries one-by-one
+# without using a single sentinel such as /usr/bin.
+_SANE_PATH_ENTRIES = (
+    "/opt/homebrew/bin",
+    "/opt/homebrew/sbin",
+    "/usr/local/sbin",
+    "/usr/local/bin",
+    "/usr/sbin",
+    "/usr/bin",
+    "/sbin",
+    "/bin",
 )
+_SANE_PATH = ":".join(_SANE_PATH_ENTRIES)
+
+
+def _current_os_home() -> str:
+    """Return the real OS user's home, ignoring subprocess HOME overrides."""
+    if _IS_WINDOWS:
+        return os.path.expanduser("~")
+    try:
+        import pwd  # POSIX-only
+
+        return pwd.getpwuid(os.getuid()).pw_dir
+    except Exception:
+        return os.path.expanduser("~")
+
+
+def _path_fill_candidates(env: dict) -> list[str]:
+    """PATH entries Hermes should fill in when a minimal service env omits them.
+
+    Entries are candidates only: callers append ones that are not already
+    present, preserving the user's existing PATH order and profile exports.
+    Include both the real OS home (for user-installed CLIs in ~/.local/bin)
+    and the subprocess HOME (for per-profile HOME isolation) when they differ.
+    """
+    candidates: list[str] = []
+    for home in (_current_os_home(), env.get("HOME", "")):
+        if not home:
+            continue
+        home = home.rstrip("/") or "/"
+        for suffix in (".local/bin", "bin"):
+            entry = os.path.join(home, suffix)
+            if entry not in candidates:
+                candidates.append(entry)
+    for entry in _SANE_PATH_ENTRIES:
+        if entry not in candidates:
+            candidates.append(entry)
+    return candidates
+
+
+def _append_missing_path_entries(existing_path: str, candidates: list[str]) -> str:
+    """Append missing PATH entries without disturbing existing order."""
+    if _IS_WINDOWS:
+        return existing_path
+    entries = existing_path.split(":") if existing_path else []
+    seen = {entry for entry in entries if entry}
+    for entry in candidates:
+        if entry and entry not in seen:
+            entries.append(entry)
+            seen.add(entry)
+    return ":".join(entries)
+
+
+def _path_fill_shell_prelude(env: dict) -> str:
+    """Shell snippet that re-applies PATH fill after login profiles run.
+
+    NixOS' /etc/profile sources a generated set-environment script that can
+    replace PATH inside ``bash -l``.  Since that happens after Popen receives
+    our env, Python-side PATH repair alone can be lost during the snapshot.
+    This prelude runs inside the login shell, after system/user profiles, and
+    only appends entries still missing at that point.
+    """
+    if _IS_WINDOWS:
+        return ""
+    quoted = " ".join(shlex.quote(entry) for entry in _path_fill_candidates(env) if entry)
+    if not quoted:
+        return ""
+    return (
+        "for __hermes_path_entry in " + quoted + "; do\n"
+        "  [ -n \"$__hermes_path_entry\" ] || continue\n"
+        "  case \":$PATH:\" in\n"
+        "    *:\"$__hermes_path_entry\":*) ;;\n"
+        "    *) PATH=\"${PATH:+$PATH:}$__hermes_path_entry\" ;;\n"
+        "  esac\n"
+        "done\n"
+        "export PATH\n"
+        "unset __hermes_path_entry\n"
+    )
 
 
