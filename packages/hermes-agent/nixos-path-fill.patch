+def _path_repair_entries(env: dict) -> list[str]:
+    """PATH entries to re-apply after a login shell has sourced profiles.
+
+    Start with the exact PATH inherited by the Hermes process (after normal
+    secret sanitization), then append the conservative fill-in candidates for
+    sparse service environments. This is intentionally not limited to a small
+    built-in allowlist: on NixOS, user profiles and the Hermes package itself
+    often live under ``~/.nix-profile/bin`` and ``/nix/store/.../bin``. Those
+    entries are already present in the trusted parent process env, and losing
+    them in ``bash -l`` is the bug this repair exists to prevent.
+    """
+    entries: list[str] = []
+    for entry in (env.get("PATH") or "").split(":"):
+        if entry and entry not in entries:
+            entries.append(entry)
+    for entry in _path_fill_candidates(env):
+        if entry and entry not in entries:
+            entries.append(entry)
+    return entries
+
