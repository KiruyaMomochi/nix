+def _message_content_for_db_compare(content: Any) -> Any:
+    """Normalize an agent message content value to the form stored in state.db."""
+
+    if isinstance(content, list):
+        parts = []
+        for part in content:
+            if not isinstance(part, dict):
+                continue
+            if part.get("type") == "text":
+                parts.append(str(part.get("text", "")))
+            elif part.get("type") in {"image", "image_url", "input_image"}:
+                parts.append("[screenshot]")
+        return "\n".join(parts) if parts else None
+    return content
+
+
+def _count_gateway_current_turn_db_prefix(
+    persisted: Any,
+    expected_entries: List[Dict[str, Any]],
+) -> int:
+    """Return how many leading current-turn entries are already in state.db.
+
+    Gateway normally skips SQLite writes because ``AIAgent`` persists the same
+    messages via ``_flush_messages_to_session_db``.  The post-compaction safety
+    fallback checks whether the current turn made it to SQLite and mirrors any
+    missing rows.  That check must be prefix-aware: if the agent persisted the
+    user row but missed the assistant row, replaying the whole turn would store
+    the user message twice.  In that case this helper returns ``1`` so callers
+    only mirror the missing assistant suffix.
+
+    Non-list/mock DB implementations keep the historical duplicate-write guard
+    by reporting the full expected length as already persisted.
+    """
+
+    expected = [
+        {
+            "role": entry.get("role"),
+            "content": _message_content_for_db_compare(entry.get("content")),
+        }
+        for entry in expected_entries
+        if entry.get("role") not in {"system", "session_meta"}
+    ]
+    if not expected:
+        return 0
+    if not isinstance(persisted, list):
+        return len(expected)
+
+    max_prefix = min(len(expected), len(persisted))
+    for prefix_len in range(max_prefix, 0, -1):
+        tail = persisted[-prefix_len:]
+        want = expected[:prefix_len]
+        if all(
+            stored.get("role") == expected_msg.get("role")
+            and stored.get("content") == expected_msg.get("content")
+            for stored, expected_msg in zip(tail, want)
+        ):
+            return prefix_len
+    return 0
+
